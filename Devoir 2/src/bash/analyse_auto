  while [[ nb_compt -le nb_resolutions ]]; do

    # Lecture des deux colonnes (Espace et Temps)
    ligne=$(head -$nb_compt $2 | tail -1)
    res_espace=$(echo "$ligne" | awk '{print $1}')
