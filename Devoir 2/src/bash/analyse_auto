USAGE="Usage: ./src/bash/analyse_auto {nom_du_programme_sans_.py} {chemin_vers_liste_resolutions}"
#
#====================================================================
# vÃĐrifier si le script a le bon nombre d'arguments (2) ou abandonner
#====================================================================
  if test $# -ne 2
  then echo "Nombre d'arguments erronÃĐ: $USAGE"
       exit
  fi
#
# ===============
# initialisations
# ===============
#
  editor=nano

  nb_resolutions=`wc -l $2 | awk '{print $1}'` # nombre de rÃĐsolution
  nb_compt=1  # compteur de la boucle

  # lecture des bornes a et b dans le fichier $1.cpp
  borne_a=`grep 'a =' $1.py | awk '{print $5}'`
  borne_b=`grep 'b =' $1.py | awk '{print $5}'`

  # enlever des 2 derniers caractÃĻres (??) de la variable chaine
  borne_a="${borne_a%??}"
