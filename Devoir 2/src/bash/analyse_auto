  echo "*******************************************"
  echo ""
  echo "--> Nombre de rÃĐsolutions testÃĐes : "$nb_resolutions
  echo ""

  echo "Analyse de convergence:" > src/bash/resultats # ÃĐcriture dans le fichier contenant les rÃĐsultats
  echo "" >> src/bash/resultats
#
# ------------------------------------------------
# verifie si le fichier $1.py du programme existe
